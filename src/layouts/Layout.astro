---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';

interface Props {
	title?: string;
}

const { title = 'Associami Subito — Il gestionale per la tua attività' } = Astro.props;
const siteUrl = 'https://www.associamisubito.it';
---

<!doctype html>
<html lang="it">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content="Gestisci prenotazioni, soci e pagamenti della tua attività in un'unica piattaforma. Centri sportivi, noleggi, scuole e molto altro." />
		<meta name="theme-color" content="#F28F16" />

		<!-- Open Graph -->
		<meta property="og:title" content="Associami Subito - Il gestionale per la tua attività" />
		<meta property="og:description" content="Gestisci prenotazioni, soci e pagamenti della tua attività in un'unica piattaforma." />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={`${siteUrl}/`} />
		<meta property="og:image" content={`${siteUrl}/images/og-image.jpg`} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content="Associami Subito - Gestionale per attività e prenotazioni" />
		<meta property="og:locale" content="it_IT" />
		<meta property="og:site_name" content="Associami Subito" />

		<!-- Twitter Cards -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="Associami Subito - Il gestionale per la tua attività" />
		<meta name="twitter:description" content="Gestisci prenotazioni, soci e pagamenti in un'unica piattaforma. Gratis, per sempre." />
		<meta name="twitter:image" content={`${siteUrl}/images/og-image.jpg`} />
		<meta name="twitter:image:alt" content="Associami Subito - Gestionale per attività e prenotazioni" />

		<!-- Schema.org JSON-LD -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Organization",
			"name": "Associami Subito",
			"url": siteUrl,
			"logo": `${siteUrl}/images/logo.png`,
			"description": "Gestionale completo per la tua attività: prenotazioni, soci, pagamenti e molto altro.",
			"contactPoint": {
				"@type": "ContactPoint",
				"contactType": "customer service",
				"availableLanguage": ["Italian", "English"]
			},
			"sameAs": []
		})} />

		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet" />

		<!-- Favicons -->
		<link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="shortcut icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />

		<!-- Google Search Console -->
		<meta name="google-site-verification" content="nWrwOfj9Cq4OgznR_q5rJKEdip7GFemN4xM7M4OkJ6k" />

		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<Navbar loginUrl="https://app.associamisubito.it/login" />
		<div class="pt-20">
			<slot />
		</div>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
