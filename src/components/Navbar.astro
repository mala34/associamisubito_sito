---
interface Props {
    loginUrl?: string;
}

const {loginUrl = 'https://app.associamisubito.it/login'} = Astro.props;
---

<nav class="fixed top-0 left-0 right-0 z-[100] glass border-b border-slate-200 h-20 flex items-center">
    <div class="max-w-[82rem] mx-auto px-4 sm:px-6 lg:px-8 w-full">
        <div class="flex justify-between items-center">
            <a href="/" class="flex items-center space-x-3 group">
                <img src="/images/logo.png" alt="Associami Subito" class="w-10 h-10 rounded-2xl shadow-lg shadow-orange-100 group-hover:scale-110 transition-transform" />
                <span class="text-2xl font-black text-slate-900 hidden sm:block tracking-tighter">
					Associami<span class="text-[#F28F16]">Subito</span>
				</span>
            </a>

            <a
                    href={loginUrl}
                    class="px-6 py-2.5 bg-slate-900 text-white text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-[#F28F16] transition-colors"
            >
                Accedi
            </a>
        </div>
    </div>
</nav>
