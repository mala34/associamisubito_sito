---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contattaci — Associami Subito">
	<main class="min-h-screen bg-white">
		<div class="relative bg-white">
			<!-- Immagine a destra (visibile solo su lg+) -->
			<div class="lg:absolute lg:inset-0 lg:left-1/2">
				<img
					alt="Campo sportivo"
					src="/images/basket.jpg"
					class="h-64 w-full bg-slate-50 object-cover sm:h-80 lg:absolute lg:h-full"
				/>
			</div>

			<!-- Form a sinistra -->
			<div class="pt-16 pb-24 sm:pt-24 sm:pb-32 lg:mx-auto lg:grid lg:max-w-7xl lg:grid-cols-2 lg:pt-32">
				<div class="px-6 lg:px-8">
					<div class="mx-auto max-w-xl lg:mx-0 lg:max-w-lg">
						<p class="text-[10px] font-black uppercase tracking-[0.3em] text-[#F28F16] mb-4">Contattaci</p>
						<h1 class="text-4xl md:text-5xl font-black text-slate-900 tracking-tighter">
							Parlaci della tua attività
						</h1>
						<p class="mt-3 text-lg text-slate-500 font-medium">
							In cosa possiamo facilitare la gestione della tua attività?
						</p>

						<form
							id="contact-form"
							class="mt-14"
						>
							<input type="text" name="_honey" style="display:none" />

							<div class="grid grid-cols-1 gap-x-8 gap-y-6 sm:grid-cols-2">
								<!-- Nome -->
								<div>
									<label for="nome" class="block text-sm font-semibold text-slate-700">
										Nome <span class="text-[#F28F16]">*</span>
									</label>
									<div class="mt-2.5">
										<input
											type="text"
											id="nome"
											name="nome"
											required
											autocomplete="given-name"
											placeholder="Il tuo nome"
											class="w-full px-4 py-3 rounded-xl border border-slate-200 text-slate-900 placeholder:text-slate-300 focus:outline-none focus:ring-2 focus:ring-[#F28F16]/30 focus:border-[#F28F16] transition-all"
										/>
									</div>
								</div>

								<!-- Cognome -->
								<div>
									<label for="cognome" class="block text-sm font-semibold text-slate-700">
										Cognome <span class="text-[#F28F16]">*</span>
									</label>
									<div class="mt-2.5">
										<input
											type="text"
											id="cognome"
											name="cognome"
											required
											autocomplete="family-name"
											placeholder="Il tuo cognome"
											class="w-full px-4 py-3 rounded-xl border border-slate-200 text-slate-900 placeholder:text-slate-300 focus:outline-none focus:ring-2 focus:ring-[#F28F16]/30 focus:border-[#F28F16] transition-all"
										/>
									</div>
								</div>

								<!-- Email -->
								<div class="sm:col-span-2">
									<label for="email" class="block text-sm font-semibold text-slate-700">
										Email <span class="text-[#F28F16]">*</span>
									</label>
									<div class="mt-2.5">
										<input
											type="email"
											id="email"
											name="email"
											required
											autocomplete="email"
											placeholder="la-tua@email.it"
											class="w-full px-4 py-3 rounded-xl border border-slate-200 text-slate-900 placeholder:text-slate-300 focus:outline-none focus:ring-2 focus:ring-[#F28F16]/30 focus:border-[#F28F16] transition-all"
										/>
									</div>
								</div>

								<!-- Telefono -->
								<div class="sm:col-span-2">
									<div class="flex justify-between text-sm">
										<label for="telefono" class="block font-semibold text-slate-700">
											Telefono
										</label>
										<p class="text-slate-400 font-medium">Opzionale</p>
									</div>
									<div class="mt-2.5 flex gap-3">
										<div class="flex items-center px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 text-slate-500 text-sm font-medium shrink-0">
											+39
										</div>
										<div class="relative flex-1">
											<input
												type="tel"
												id="telefono"
												name="telefono"
												maxlength="10"
												autocomplete="tel"
												placeholder="3331234567"
												pattern="[0-9]{0,10}"
												class="w-full px-4 py-3 rounded-xl border border-slate-200 text-slate-900 placeholder:text-slate-300 focus:outline-none focus:ring-2 focus:ring-[#F28F16]/30 focus:border-[#F28F16] transition-all"
											/>
											<span id="char-count" class="absolute right-3 top-1/2 -translate-y-1/2 text-[11px] text-slate-300 font-medium">
												0 di 10 caratteri max.
											</span>
										</div>
									</div>
								</div>

								<!-- Messaggio -->
								<div class="sm:col-span-2">
									<div class="flex justify-between text-sm">
										<label for="messaggio" class="block font-semibold text-slate-700">
											Parlaci della tua attività
										</label>
										<p id="message-description" class="text-slate-400 font-medium">Max 500 caratteri</p>
									</div>
									<div class="mt-2.5">
										<textarea
											id="messaggio"
											name="messaggio"
											rows="4"
											maxlength="500"
											aria-describedby="message-description"
											placeholder="Descrivi la tua attività e come possiamo aiutarti..."
											class="w-full px-4 py-3 rounded-xl border border-slate-200 text-slate-900 placeholder:text-slate-300 focus:outline-none focus:ring-2 focus:ring-[#F28F16]/30 focus:border-[#F28F16] transition-all resize-none"
										></textarea>
									</div>
								</div>
							</div>

							<!-- Submit -->
							<div class="mt-10 flex justify-end border-t border-slate-100 pt-8">
								<button
									id="submit-btn"
									type="submit"
									class="px-10 py-4 bg-[#F28F16] text-white font-bold rounded-2xl hover:scale-105 hover:shadow-lg hover:shadow-orange-200 transition-all cursor-pointer disabled:opacity-50 disabled:hover:scale-100"
								>
									Invia
								</button>
							</div>
						</form>

						<!-- Success message -->
						<div id="success-message" class="hidden mt-8 p-6 rounded-2xl bg-emerald-50 border border-emerald-200">
							<p class="text-emerald-700 font-semibold text-center">Messaggio inviato con successo!</p>
							<p class="text-emerald-600 text-sm mt-2 text-center">La tua richiesta è stata inviata a <strong>info@prenotamisubito.it</strong>. Ti risponderemo al più presto.</p>
						</div>

						<!-- Error message -->
						<div id="error-message" class="hidden mt-8 p-6 rounded-2xl bg-red-50 border border-red-200">
							<p class="text-red-700 font-semibold text-center">Si è verificato un errore.</p>
							<p class="text-red-600 text-sm mt-2 text-center">Non siamo riusciti ad inviare il messaggio. Riprova o scrivici direttamente a <a href="mailto:info@prenotamisubito.it" class="underline font-semibold">info@prenotamisubito.it</a></p>
						</div>
					</div>
				</div>
			</div>
		</div>

		<!-- Footer -->
		<footer class="py-16 border-t border-slate-200 bg-white">
			<div class="max-w-7xl mx-auto px-4">
				<div class="flex flex-col md:flex-row justify-between items-center gap-10">
					<div class="flex items-center gap-3">
						<img src="/images/logo.png" alt="Associami Subito" class="w-8 h-8 rounded-xl"/>
						<span class="text-xl font-black text-slate-900 tracking-tighter">
							Associami<span class="text-[#F28F16]">Subito</span>
						</span>
					</div>
					<div class="flex flex-wrap justify-center gap-8">
						<span class="text-[10px] font-black uppercase tracking-widest text-slate-400 cursor-pointer hover:text-[#F28F16] transition-colors">Privacy Policy</span>
						<span class="text-[10px] font-black uppercase tracking-widest text-slate-400 cursor-pointer hover:text-[#F28F16] transition-colors">Termini</span>
						<a href="/contattaci" class="text-[10px] font-black uppercase tracking-widest text-[#F28F16] hover:text-[#F28F16] transition-colors">Contatti</a>
						<span class="text-[10px] font-black uppercase tracking-widest text-slate-400 cursor-pointer hover:text-[#F28F16] transition-colors">Supporto</span>
					</div>
				</div>
				<div class="mt-10 pt-10 border-t border-slate-100 text-center space-y-2">
					<p class="text-slate-400 text-xs">
						Piazza Sergio Finocchi, 3 — 41017 Spilamberto (MO) &middot; Tel. <a href="tel:+393480407500" class="hover:text-[#F28F16] transition-colors">348.0407500</a> &middot; P.IVA 03447571203
					</p>
					<p class="text-slate-300 text-[10px] font-black uppercase tracking-[0.3em]">
						&copy; {new Date().getFullYear()} Associami Subito. All rights reserved.
					</p>
				</div>
			</div>
		</footer>
	</main>
</Layout>

<script>
	// Character counter for phone input
	const phoneInput = document.getElementById('telefono') as HTMLInputElement;
	const charCount = document.getElementById('char-count');

	if (phoneInput && charCount) {
		phoneInput.addEventListener('input', () => {
			phoneInput.value = phoneInput.value.replace(/\D/g, '').slice(0, 10);
			charCount.textContent = `${phoneInput.value.length} di 10 caratteri max.`;
		});
	}

	// Form submission via AJAX
	const form = document.getElementById('contact-form') as HTMLFormElement;
	const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
	const successMsg = document.getElementById('success-message')!;
	const errorMsg = document.getElementById('error-message')!;

	form.addEventListener('submit', async (e) => {
		e.preventDefault();

		// Hide previous messages
		successMsg.classList.add('hidden');
		errorMsg.classList.add('hidden');

		// Disable button and show loading
		const originalText = submitBtn.textContent;
		submitBtn.disabled = true;
		submitBtn.textContent = 'Invio in corso...';

		// Collect form data
		const formData = new FormData(form);

		// Honeypot check (spam)
		if (formData.get('_honey')) return;

		// Build payload
		const data = {
			nome: formData.get('nome'),
			cognome: formData.get('cognome'),
			email: formData.get('email'),
			telefono: formData.get('telefono') ? `+39 ${formData.get('telefono')}` : 'Non fornito',
			messaggio: formData.get('messaggio') || 'Nessun messaggio',
			_subject: 'Nuovo contatto da Associami Subito',
			_captcha: 'false',
			_template: 'table',
		};

		try {
			const response = await fetch('https://formsubmit.co/ajax/info@prenotamisubito.it', {
				method: 'POST',
				headers: {
					'Content-Type': 'application/json',
					'Accept': 'application/json',
				},
				body: JSON.stringify(data),
			});

			if (response.ok) {
				successMsg.classList.remove('hidden');
				form.reset();
				if (charCount) charCount.textContent = '0 di 10 caratteri max.';
				// Scroll to success message
				successMsg.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
			} else {
				throw new Error('Errore invio');
			}
		} catch {
			errorMsg.classList.remove('hidden');
			errorMsg.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
		} finally {
			submitBtn.disabled = false;
			submitBtn.textContent = originalText;
		}
	});
</script>
